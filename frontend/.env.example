# ─── Frontend env template ──────────────────────────────────────────────────
# Copy to .env.local (gitignored) and fill in real values.
# NEVER put real secrets in this file — it is committed to git.

# LLM providers (server-only)
GEMINI_API_KEY=your-google-ai-studio-key
GROQ_API_KEY=your-groq-key

# Express backend base URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ─── Auth0 (@auth0/nextjs-auth0 v4) ──────────────────────────────────────────
# Tenant + API
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_SCOPE=openid profile email
# Regular Web Application credentials
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
# 32-byte hex for cookie encryption — generate with: openssl rand -hex 32
AUTH0_SECRET=generate-with-openssl-rand-hex-32
# Public base URL of this app
APP_BASE_URL=http://localhost:3000
