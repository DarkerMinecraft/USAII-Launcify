generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String           @id @default(cuid())
  auth0Id   String           @unique
  email     String           @unique
  name      String?
  picture   String?
  provider  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  sessions  WarRoomSession[]
}

model WarRoomSession {
  id                     String           @id @default(cuid())
  userId                 String
  ideaSummary            String
  questionnaireResponses Json
  canvas                 Json?
  status                 SessionStatus    @default(IN_PROGRESS)
  outreachDraft          Json?
  executiveSummary       Json?
  validationRoadmap      Json?
  marketResearch         Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  assumptions            AssumptionNode[]
  transcript             DebateMessage[]
  user                   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DebateMessage {
  id        String         @id @default(cuid())
  sessionId String
  agent     AgentRole
  round     Int
  content   String
  createdAt DateTime       @default(now())
  session   WarRoomSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, agent, round])
}

model AssumptionNode {
  id          String         @id @default(cuid())
  sessionId   String
  claim       String
  status      NodeStatus
  explanation String
  agentSource AgentRole
  howToTest   String?
  remediation Json?
  createdAt   DateTime       @default(now())
  session     WarRoomSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETE
}

enum AgentRole {
  SKEPTIC
  STRATEGIST
  OPERATOR
}

enum NodeStatus {
  VALIDATED
  UNVALIDATED
  NEEDS_INFO
}
