generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// prisma/schema.prisma
datasource db {
  provider = "postgresql"
}


model User {
  id          String   @id @default(cuid())

  auth0Id     String   @unique

  email       String   @unique
  name        String?
  picture     String?

  provider    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}